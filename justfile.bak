default:
  just --list

all: install-cli-tools install-dev-tools

update-system:
  sudo apt update

upgrade-system: update-system
  sudo apt upgrade -y

install-cli-tools: update-system
  sudo apt install -y \
    fzf \
    tmux \
    unzip \
    wget

  cargo binstall -y \
    bat \
    bottom \
    du-dust \
    exa \
    fd-find \
    ripgrep

install-nerd-font: install-cli-tools
  mkdir -p $HOME/.local/share/fonts

  wget -O $HOME/.local/share/fonts/FiraCode.zip https://github.com/ryanoasis/nerd-fonts/releases/download/v3.0.2/FiraCode.zip

  unzip -o -d $HOME/.local/share/fonts/ $HOME/.local/share/fonts/FiraCode.zip

  rm $HOME/.local/share/fonts/FiraCode.zip



install-cli-customization: update-system install-nerd-font
  sudo apt install -y \
    zsh

  cargo binstall -y starship




install-package-tools: update-system
  sudo apt install -y software-properties-common

install-python: install-package-tools
  sudo add-apt-repository -y ppa:deadsnakes/ppa
  sudo apt install -y \
    pip \
    python3 \
    python3-pip \

  pip3 install --upgrade pip

install-git:
  sudo apt install -y \
    git

install-cmake: install-python
  pip install cmake

install-neovim: install-git install-cmake
  -git clone https://github.com/neovim/neovim $HOME/neovim
  cd $HOME/neovim && \
    git checkout stable && \
    make CMAKE_BUILD_TYPE=Release CMAKE_EXTRA_FLAGS="-DCMAKE_INSTALL_PREFIX=$HOME/neovim" && \
    make install

  export PATH="$HOME/neovim/bin:$PATH"

install-dev-tools: update-system install-python install-neovim
  sudo apt install -y \
    ninja-build

  pip install \
    rich
