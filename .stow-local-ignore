# Stow ignore file — patterns are Perl regex, anchored.
# Patterns without `/` match basenames at any depth.
# Patterns with `/` match paths relative to the package root.

# VCS / metadata
\.git
\.gitmodules
\.gitignore

# Stow's own files
\.stowrc
\.stow-local-ignore

# Repo docs / scripts / install plumbing (not config)
^/README\.md
^/justfile
^/bootstrap\.sh
^/scripts
^/keyboard_layout
^/\.docker

# ~/.zshrc is now generated by home-manager (see modules/nixosModules/home);
# user-iterated bits live in .zsh/extra.zsh which is still stowed.
^/\.zshrc

# Nix flake / modules (system config, not stowed)
^/flake\.nix
^/flake\.lock
^/modules

# Editor leftovers
.+\.swp$
.+\.bak$
