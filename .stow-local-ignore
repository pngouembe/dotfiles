# Stow ignore file — patterns are Perl regex, anchored.
# Patterns without `/` match basenames at any depth.
# Patterns with `/` match paths relative to the package root.

# VCS and stow metadata
\.git
\.stowrc
\.stow-local-ignore

# Repo docs and install plumbing (not config)
^/README\.md
^/justfile
^/bootstrap\.sh
^/scripts
^/keyboard_layout
^/\.docker

# Nix flake and modules (system config, not stowed)
^/flake\.nix
^/flake\.lock
^/nix

# Editor leftovers
.+\.swp$
.+\.bak$
